# Cloudflare
# CLOUDFLARE_IS_PREVIEW=true
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_D1_DATABASE_ID=""
CLOUDFLARE_D1_PREVIEW_DATABASE_ID=""
CLOUDFLARE_D1_TOKEN=""

# App bootstrap
IDP_DEFAULT_TENANT_NAME=""
IDP_BOOTSTRAP_ADMIN_USERNAME=""
IDP_BOOTSTRAP_ADMIN_EMAIL=""
IDP_BOOTSTRAP_ADMIN_PASSWORD=""
IDP_BOOTSTRAP_ADMIN_NAME=""

# OIDC 서명 키 암호화 비밀. 32자 이상 랜덤 문자열.
IDP_SIGNING_KEY_SECRET=your-very-long-random-secret-at-least-32-chars

# OIDC issuer URL. 미설정 시 요청 origin(http://localhost:8787)으로 자동 대체.
IDP_ISSUER_URL=http://localhost:5173