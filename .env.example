# =============================================================================
# Cloudflare
# =============================================================================

# Cloudflare 계정 ID (대시보드 우측 하단에서 확인)
CLOUDFLARE_ACCOUNT_ID=""

# D1 데이터베이스 ID (`wrangler d1 create` 명령 결과값)
CLOUDFLARE_D1_DATABASE_ID=""

# 프리뷰용 D1 데이터베이스 ID (선택, 없으면 위와 동일하게 설정)
CLOUDFLARE_D1_PREVIEW_DATABASE_ID=""

# Cloudflare D1 API 토큰 (db:migrate 스크립트에서 사용, 커밋하지 마세요)
CLOUDFLARE_D1_TOKEN=""

# =============================================================================
# IDP 부트스트랩 — 최초 배포 시 관리자 계정 자동 생성
# 배포 후 관리자 UI에서 비밀번호를 변경하거나 아래 변수를 제거하세요.
# =============================================================================

# 기본 테넌트 이름
IDP_DEFAULT_TENANT_NAME="My Organization"

# 초기 관리자 아이디 (기본: admin)
IDP_BOOTSTRAP_ADMIN_USERNAME="admin"

# 초기 관리자 이메일
IDP_BOOTSTRAP_ADMIN_EMAIL="admin@example.com"

# 초기 관리자 비밀번호 (⚠️ 프로덕션에서는 wrangler secret put 사용)
IDP_BOOTSTRAP_ADMIN_PASSWORD=""

# 초기 관리자 표시 이름
IDP_BOOTSTRAP_ADMIN_NAME="관리자"

# =============================================================================
# IDP 핵심 설정
# =============================================================================

# 서명 키 암호화 KEK — 최소 32자 랜덤 문자열
# 생성: openssl rand -base64 32
# ⚠️ 프로덕션에서는 wrangler secret put IDP_SIGNING_KEY_SECRET 사용
IDP_SIGNING_KEY_SECRET="your-very-long-random-secret-at-least-32-chars"

# OIDC/SAML issuer URL (배포 도메인과 일치시킬 것)
# 미설정 시 요청 origin으로 자동 대체 (로컬 개발 시 http://localhost:5173)
IDP_ISSUER_URL="http://localhost:5173"
