{
    "name": "keystone",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
        "prepare": "svelte-kit sync || echo '' && lefthook install || echo ''",
        "check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "typecheck": "tsc --noEmit",
        "lint": "prettier --check . && eslint .",
        "lint:fix": "eslint --fix . && prettier --write .",
        "format": "prettier --write .",
        "gen": "wrangler types",
        "deploy": "wrangler deploy",
        "deploy:build": "vite build && wrangler deploy",
        "db:generate": "drizzle-kit generate --dialect=sqlite --schema=./src/lib/server/db/schema.sqlite.ts --out=./drizzle",
        "db:generate:pg": "DB_DIALECT=postgres drizzle-kit generate",
        "db:generate:mysql": "DB_DIALECT=mysql drizzle-kit generate",
        "db:generate:sqlite": "DB_DIALECT=sqlite drizzle-kit generate",
        "db:generate:all": "bun run db:generate && bun run db:generate:pg && bun run db:generate:mysql && bun run db:generate:sqlite",
        "db:check": "bun run db:check:d1 && bun run db:check:pg && bun run db:check:mysql && bun run db:check:sqlite",
        "db:check:d1": "drizzle-kit check",
        "db:check:pg": "DB_DIALECT=postgres drizzle-kit check",
        "db:check:mysql": "DB_DIALECT=mysql drizzle-kit check",
        "db:check:sqlite": "DB_DIALECT=sqlite drizzle-kit check",
        "db:push": "drizzle-kit push",
        "db:migrate": "drizzle-kit migrate && bun run db:seed:migrate",
        "db:migrate:preview": "CLOUDFLARE_IS_PREVIEW=true drizzle-kit migrate && bun run db:seed:migrate:preview",
        "db:seed": "bun scripts/seed.ts",
        "db:reset-admin": "bun scripts/reset-admin-password.ts",
        "db:reset-admin:pg": "DB_DIALECT=postgres bun scripts/reset-admin-password.ts",
        "db:reset-admin:mysql": "DB_DIALECT=mysql bun scripts/reset-admin-password.ts",
        "db:reset-admin:sqlite": "DB_DIALECT=sqlite bun scripts/reset-admin-password.ts",
        "db:seed:preview": "CLOUDFLARE_IS_PREVIEW=true bun scripts/seed.ts",
        "db:seed:migrate": "bun scripts/seed-migrate.ts",
        "db:seed:migrate:preview": "CLOUDFLARE_IS_PREVIEW=true bun scripts/seed-migrate.ts",
        "db:studio": "drizzle-kit studio",
        "db:migrate:pg": "DB_DIALECT=postgres drizzle-kit migrate && DB_DIALECT=postgres bun scripts/seed-migrate.ts",
        "db:seed:pg": "DB_DIALECT=postgres bun scripts/seed.ts",
        "db:push:pg": "DB_DIALECT=postgres drizzle-kit push",
        "db:studio:pg": "DB_DIALECT=postgres drizzle-kit studio",
        "db:migrate:mysql": "DB_DIALECT=mysql drizzle-kit migrate && DB_DIALECT=mysql bun scripts/seed-migrate.ts",
        "db:seed:mysql": "DB_DIALECT=mysql bun scripts/seed.ts",
        "db:push:mysql": "DB_DIALECT=mysql drizzle-kit push",
        "db:studio:mysql": "DB_DIALECT=mysql drizzle-kit studio",
        "db:migrate:sqlite": "DB_DIALECT=sqlite drizzle-kit migrate && DB_DIALECT=sqlite bun scripts/seed-migrate.ts",
        "db:seed:sqlite": "DB_DIALECT=sqlite bun scripts/seed.ts",
        "db:push:sqlite": "DB_DIALECT=sqlite drizzle-kit push",
        "db:studio:sqlite": "DB_DIALECT=sqlite drizzle-kit studio",
        "setup": "bun run scripts/setup.ts",
        "verify:saml-encryption": "bun scripts/verify-saml-encryption.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@eslint/compat": "^2.1.0",
        "@eslint/js": "^10.0.1",
        "@simplewebauthn/browser": "^13.3.0",
        "@sveltejs/adapter-cloudflare": "^7.2.9",
        "@sveltejs/adapter-node": "^5.5.7",
        "@sveltejs/kit": "^2.70.1",
        "@sveltejs/vite-plugin-svelte": "^7.2.0",
        "@tailwindcss/vite": "^4.3.3",
        "@types/node": "^26.1.1",
        "@types/nodemailer": "^8.0.1",
        "@types/qrcode": "^1.5.6",
        "@vitest/coverage-v8": "^4.1.10",
        "drizzle-kit": "^0.31.10",
        "drizzle-orm": "^0.45.2",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.21.0",
        "globals": "^17.7.0",
        "lefthook": "^2.1.10",
        "prettier": "^3.9.5",
        "prettier-plugin-svelte": "^4.1.1",
        "prettier-plugin-tailwindcss": "^0.8.1",
        "qrcode": "^1.5.4",
        "svelte": "^5.56.6",
        "svelte-check": "^4.7.3",
        "tailwindcss": "^4.3.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.64.0",
        "vite": "^8.1.5",
        "vitest": "^4.1.10",
        "wrangler": "^4.112.0"
    },
    "dependencies": {
        "@hicaru/argon2-pure.js": "^0.0.4",
        "@libsql/client": "^0.17.4",
        "@peculiar/x509": "^2.0.0",
        "@simplewebauthn/server": "^13.3.2",
        "@xmldom/xmldom": "^0.9.10",
        "@yrneh_jang/ldapjs": "^3.1.1",
        "aws4fetch": "^1.0.20",
        "mysql2": "^3.23.1",
        "nodemailer": "^9.0.3",
        "postgres": "^3.4.9",
        "reflect-metadata": "^0.2.2",
        "xml-core": "^1.2.5",
        "xmldsigjs": "^2.8.7",
        "xpath": "^0.0.34",
        "zod": "^4.4.3"
    },
    "overrides": {
        "ws": "^8.21.0",
        "cookie": ">=0.7.0",
        "esbuild": ">=0.25.0",
        "brace-expansion": ">=5.0.6"
    }
}
